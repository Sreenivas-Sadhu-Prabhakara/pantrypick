---
import '../styles/global.css';

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const site = 'https://sreenivas-sadhu-prabhakara.github.io/pantrypick/';
// Build a base-correct href for any public asset.
const asset = (p) => `${base.replace(/\/$/, '')}/${p.replace(/^\//, '')}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'none'; base-uri 'self'; form-action 'none'; object-src 'none'"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#c24a2e" />
    <link rel="canonical" href={site} />

    <!-- Icons & installability (all base-aware) -->
    <link rel="icon" href={asset('favicon.svg')} type="image/svg+xml" />
    <link rel="icon" href={asset('icon-192.png')} sizes="192x192" type="image/png" />
    <link rel="apple-touch-icon" href={asset('apple-touch-icon.png')} sizes="180x180" />
    <link rel="manifest" href={asset('manifest.webmanifest')} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={site} />
    <meta property="og:site_name" content="pantrypick" />
    <meta property="og:image" content="https://sreenivas-sadhu-prabhakara.github.io/pantrypick/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="pantrypick — what can I cook with the ingredients I have? An index card showing a recipe you have every ingredient for." />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://sreenivas-sadhu-prabhakara.github.io/pantrypick/og.png" />
  </head>
  <body>
    <slot />
  </body>
</html>
